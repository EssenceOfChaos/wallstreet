<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><%=displayTitle()%></title>
    <!-- Semantic-UI minified CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/semantic-ui@2.4.2/dist/semantic.min.css">    <link href="https://fonts.googleapis.com/css?family=Ubuntu:400,700" rel="stylesheet" />
    <link rel="stylesheet" href="<%= Routes.static_path(@conn, "/css/app.css") %>"/>
  </head>
  <body>
    <%= render "_navbar.html", conn: @conn %>
    <div class="ui container" id="app-wrapper">
    <br>

      <p class="alert alert-info" role="alert"><%= get_flash(@conn, :info) %></p>
      <p class="alert alert-danger" role="alert"><%= get_flash(@conn, :error) %></p>
      <main role="main">
        <%= if Map.has_key?(@conn.assigns, :sidebar) do %>
          <%= render "sidebar.html", conn: @conn %>
          <div class="main">
            <%= render @view_module, @view_template, assigns %>
          </div>
        <% else %>
        <%= render @view_module, @view_template, assigns %>
        <% end %>
      </main>
    </div>
    <%= render "_footer.html", conn: @conn %>
     <script>window.userToken = "<%= assigns[:user_token] %>"</script>
    <script src="https://code.jquery.com/jquery-3.3.1.slim.min.js" integrity="sha384-q8i/X+965DzO0rT7abK41JStQIAqVgRVzpbzo5smXKp4YfRvH+8abtTE1Pi6jizo" crossorigin="anonymous"></script>
    <!-- Semantic-UI minified JS -->
    <script src="https://cdn.jsdelivr.net/npm/semantic-ui@2.4.2/dist/semantic.min.js"></script>
    <script type="text/javascript" src="<%= Routes.static_path(@conn, "/js/app.js") %>"></script>
  </body>
</html>
