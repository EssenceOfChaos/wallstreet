

<section class="phx-hero">
  <h1><%= gettext "Welcome to %{name}!", name: "WallStreet" %></h1>
  <p>Real stocks, real data, play money!</p>
</section>

<h1 class="ui header">Semantic UI Fixed Template</h1>
<p>This is a basic fixed menu template using fixed size containers.</p>
<p>Lorem Ipsum Text</p>
 <%= if Wallstreet.Auth.Accounts.get_current_user(@conn) do %>
<p><%= link raw(~s'<i class="user circle icon"></i>Profile'), to: Routes.user_path(@conn, :show, @current_user.id), class: "ui green button" %></p>
<%end%>
<img class="wireframe" src="/images/media-paragraph.png">
<img class="wireframe" src="/images/paragraph.png">
<img class="wireframe" src="/images/paragraph.png">
